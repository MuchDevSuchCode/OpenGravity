{
  "name": "opengravity",
  "displayName": "OpenGravity",
  "description": "AI Agent powered by OpenGravity",
  "version": "0.0.4",
  "publisher": "opengravity",
  "repository": {
    "type": "git",
    "url": "https://github.com/opengravity/opengravity.git"
  },
  "icon": "opengravitylogo.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "opengravity-sidebar-v3",
          "title": "OpenGravity",
          "icon": "opengravitylogo.png"
        }
      ]
    },
    "views": {
      "opengravity-sidebar-v3": [
        {
          "type": "webview",
          "id": "opengravity.chatView",
          "name": "Chat",
          "icon": "opengravitylogo.png"
        }
      ]
    },
    "commands": [
      {
        "command": "opengravity.applyCode",
        "title": "OpenGravity: Update Code"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "OpenGravity",
      "properties": {
        "opengravity.provider": {
          "type": "string",
          "enum": [
            "ollama",
            "lmstudio"
          ],
          "default": "ollama",
          "description": "AI API Provider (Ollama or LM Studio)"
        },
        "opengravity.url": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "URL of the local server (Ollama: 11434, LM Studio: 1234)"
        },
        "opengravity.model": {
          "type": "string",
          "default": "llama3",
          "description": "Model to use for generation"
        },
        "opengravity.systemPrompt": {
          "type": "string",
          "default": "",
          "description": "Custom global instructions appended to the agent's absolute system prompt"
        },
        "opengravity.temperature": {
          "type": "number",
          "default": 0.2,
          "description": "Temperature for generation"
        },
        "opengravity.maxTokens": {
          "type": "integer",
          "default": -1,
          "description": "Max tokens to generate (-1 for unlimited)"
        },
        "opengravity.contextLength": {
          "type": "integer",
          "default": 8192,
          "description": "Max Context Length (num_ctx), highly recommended to increase for codebase context"
        },
        "opengravity.topP": {
          "type": "number",
          "default": 0.5,
          "description": "Nucleus Sampling (top_p). Lower values (0.5) limit vocabulary for more exact/deterministic coding answers."
        },
        "opengravity.topK": {
          "type": "integer",
          "default": 40,
          "description": "Top-K Sampling (top_k). Restricts generation to the K most likely tokens."
        },
        "opengravity.enableAutocomplete": {
          "type": "boolean",
          "default": true,
          "description": "Enable inline ghost text autocomplete"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "marked": "^17.0.3"
  }
}